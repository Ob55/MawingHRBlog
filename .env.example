# --- Weekly blog automation (automation/publish-weekly.js) ---

# Free Pexels API key — REQUIRED for the auto-publisher to fetch cover images.
# Get one in two minutes:
#   1. Create a free account at https://www.pexels.com/
#   2. Go to https://www.pexels.com/api/ and click "Get Started" / "Your API Key"
#   3. Copy the key shown and paste it below.
# No app review or approval is needed — the key works immediately.
PEXELS_API_KEY=your_pexels_api_key_here

# Optional overrides. Leave unset to use the live Vercel deployment.
# BLOG_DRAFT_URL=https://mawing-hr-blog.vercel.app/api/draft
# BLOG_POSTS_URL=https://mawing-hr-blog.vercel.app/api/posts

# --- Approval email (SMTP) ---
# The weekly job emails an Approve/Reject link before anything goes live.
# The email is sent by automation/send-email.js over SMTP (zero dependencies).
# In production these are GitHub Actions secrets; locally they live in this .env.
MAIL_HOST=smtp.office365.com
MAIL_PORT=587
MAIL_USERNAME=info@ignis-innovation.com
MAIL_PASSWORD=your_smtp_password_here
MAIL_FROM_ADDRESS=info@ignis-innovation.com
MAIL_FROM_NAME=Mawingu HR Blog
APPROVAL_EMAIL_TO=brian55mwangi@gmail.com

# --- Vercel serverless functions (only needed for `vercel dev`) ---
# The blog API runs on Vercel and only needs GitHub access; NO email vars there.
# Optionally set APPROVE_SECRET on Vercel to sign approve/reject links
# (otherwise it falls back to GITHUB_TOKEN automatically).
# GITHUB_TOKEN=...
# GITHUB_OWNER=Ob55
# GITHUB_REPO=MawingHRBlog
# GITHUB_BRANCH=main
# APPROVE_SECRET=any-long-random-string
