# --- Weekly blog automation (automation/publish-weekly.js) ---

# Free Pexels API key — REQUIRED for the auto-publisher to fetch cover images.
# Get one in two minutes:
#   1. Create a free account at https://www.pexels.com/
#   2. Go to https://www.pexels.com/api/ and click "Get Started" / "Your API Key"
#   3. Copy the key shown and paste it below.
# No app review or approval is needed — the key works immediately.
PEXELS_API_KEY=your_pexels_api_key_here

# Optional overrides. Leave unset to use the live Vercel deployment.
# BLOG_DRAFT_URL=https://mawing-hr-blog.vercel.app/api/draft
# BLOG_POSTS_URL=https://mawing-hr-blog.vercel.app/api/posts

# --- Weekly website report (automation/weekly-report.js) ---
# Emails admin@mawinguhrsolutions.co.ke a weekly views + activity summary
# (instead of a dashboard). In production these are GitHub Actions secrets.
# SITE_STATS_URL: the main website's stats endpoint (Express app, NOT this repo).
SITE_STATS_URL=https://www.mawinguhrsolutions.co.ke/api/stats
# STATS_TOKEN: shared secret guarding /api/stats. MUST match STATS_TOKEN set on
# the main website (Mwebsite). Use any long random string.
STATS_TOKEN=any-long-random-string
REPORT_EMAIL_TO=admin@mawinguhrsolutions.co.ke

# --- Approval email (SMTP) ---
# The weekly job emails an Approve/Reject link before anything goes live.
# The email is sent by automation/send-email.js over SMTP (zero dependencies).
# In production these are GitHub Actions secrets; locally they live in this .env.
MAIL_HOST=smtp.office365.com
MAIL_PORT=587
MAIL_USERNAME=info@ignis-innovation.com
MAIL_PASSWORD=your_smtp_password_here
MAIL_FROM_ADDRESS=info@ignis-innovation.com
MAIL_FROM_NAME=Mawingu HR Blog
APPROVAL_EMAIL_TO=brian55mwangi@gmail.com

# --- Vercel serverless functions ---
# The blog API runs on Vercel. It needs GitHub access, AND (new) the SMTP MAIL_*
# vars above, because /api/approve now emails the admin when a post goes live and
# /api/regenerate triggers a fresh draft.
#   - GITHUB_TOKEN must have "Contents: Read and write" AND "Actions: write"
#     (Actions: write is required for the Regenerate button to start a new run).
#   - PUBLISH_NOTIFY_TO: who gets the "new blog is live" email (default
#     admin@mawinguhrsolutions.co.ke).
#   - SITE_BLOG_URL: link used in that email (the public blog page).
# GITHUB_TOKEN=...
# GITHUB_OWNER=Ob55
# GITHUB_REPO=MawingHRBlog
# GITHUB_BRANCH=main
# APPROVE_SECRET=any-long-random-string
# PUBLISH_NOTIFY_TO=admin@mawinguhrsolutions.co.ke
# SITE_BLOG_URL=https://www.mawinguhrsolutions.co.ke/blog
# PUBLISH_WORKFLOW_FILE=weekly-blog.yml
